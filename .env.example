# Data directory for SQLite database persistence
DATA_PATH=./data

# Security - MUST change in production
# openssl rand -hex 32
JWT_SECRET=navigation-site-jwt-secret-key-change-in-production-2024

# Email (SMTP) configuration for password reset
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your-email@163.com
SMTP_PASSWORD=your-smtp-password

# Frontend URL (used in password reset email links)
FRONTEND_URL=http://localhost:20261

# CORS allowed origins (comma-separated, must match FRONTEND_URL)
CORS_ORIGINS=http://localhost:20261

# Host port for the frontend (default: 20261)
PORT=20261
